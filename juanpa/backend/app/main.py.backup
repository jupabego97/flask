@app.post("/api/v1/cards/{card_id}/review", response_model=m.CardRead)
def review_card(*, session: Session = Depends(get_session), card_id: int, review_input: m.CardReviewPayload):
    card = session.get(db.Card, card_id)
    if not card:
        raise HTTPException(status_code=404, detail="Card not found")
    
    if not FSRS_AVAILABLE:
        # Fallback simple sin FSRS
        next_review = datetime.now(timezone.utc) + timedelta(days=1)
        card.next_review_at = next_review
        session.add(card)
        session.commit()
        session.refresh(card)
        return card
    
    # Usar FSRS para calcular el próximo repaso
    try:
        # Crear objeto FSRS Card
        fsrs_card = FSRSCard()
        fsrs_card.due = card.next_review_at or datetime.now(timezone.utc)
        fsrs_card.lapses = card.fsrs_lapses or 0
        fsrs_card.stability = card.fsrs_stability or 1.0
        fsrs_card.difficulty = card.fsrs_difficulty or 5.0

        # Mapear el rating del usuario
        if review_input.rating == 1:
            fsrs_rating = FSRSRating.Again
        elif review_input.rating == 2:
            fsrs_rating = FSRSRating.Hard
        elif review_input.rating == 3:
            fsrs_rating = FSRSRating.Good
        elif review_input.rating == 4:
            fsrs_rating = FSRSRating.Easy
        else:
            raise HTTPException(status_code=400, detail="Invalid rating")
        
        # Crear scheduler y calcular próximo repaso
        scheduler = Scheduler()
        updated_card, _ = scheduler.review_card(fsrs_card, fsrs_rating)
        
        # Actualizar tarjeta con nuevos valores
        card.next_review_at = updated_card.due
        card.fsrs_stability = updated_card.stability
        card.fsrs_difficulty = updated_card.difficulty
        card.fsrs_lapses = updated_card.lapses
        
        # También agregar estado FSRS si está disponible
        if hasattr(updated_card, 'state'):
            if updated_card.state == State.Learning:
                card.fsrs_state = 0
            elif updated_card.state == State.Review:
                card.fsrs_state = 1
            elif updated_card.state == State.Relearning:
                card.fsrs_state = 2
            else:
                card.fsrs_state = 1  # Default a Review
        
    except Exception as e:
        print(f"Error con FSRS: {e}")
        # Fallback a sistema simple
        next_review = datetime.now(timezone.utc) + timedelta(days=1)
        card.next_review_at = next_review
    
    # Crear log de revisión
    review_log = db.ReviewLog(
        card_id=card_id,
        rating=review_input.rating,
        reviewed_at=datetime.now(timezone.utc)
    )
    session.add(review_log)
    session.add(card)
    session.commit() 
    session.refresh(card)
    return card

@app.get("/api/v1/review/next-card", response_model=Optional[m.CardReadWithDeck])
def get_next_review_card(
    *,
    session: Session = Depends(get_session),
    deck_id: Optional[int] = Query(None, description="ID del mazo para filtrar las tarjetas a repasar. Si no se proporciona, se consideran todos los mazos.")
):
    """
    Obtiene la próxima tarjeta que necesita repaso, 
    priorizando las que están vencidas o que nunca han sido repasadas.
    """
    now = datetime.now(timezone.utc)
    
    # Query base: tarjetas que necesitan repaso
    query = select(db.Card).where(
        or_(
            db.Card.next_review_at.is_(None),  # Nunca repasadas
            db.Card.next_review_at <= now      # Vencidas
        )
    )
    
    # Filtrar por deck si se especifica
    if deck_id:
        query = query.where(db.Card.deck_id == deck_id)
    
    # Ordenar: primero las nunca repasadas, luego las más vencidas
    query = query.order_by(
        db.Card.next_review_at.asc().nulls_first(),
        db.Card.id.asc()  # Orden consistente como tiebreaker
    )
    
    card = session.exec(query).first()
    
    if card:
        # La respuesta incluirá automáticamente los datos del deck por la relación
        return card
    else:
        # No hay tarjetas pendientes
        return None

@app.get("/api/v1/stats/heatmap-data", response_model=Dict[str, int])
def get_heatmap_data(session: Session = Depends(get_session)):
    """
    Obtiene datos para el heatmap de actividad de repaso.
    Retorna un diccionario con fechas (YYYY-MM-DD) como keys y conteos como values.
    """
    # Obtener datos de los últimos 365 días
    end_date = datetime.now(timezone.utc).date()
    start_date = end_date - timedelta(days=365)
    
    # Query para contar repasos por día
    query = select(
        func.date(db.ReviewLog.reviewed_at).label("review_date"),
        func.count(db.ReviewLog.id).label("review_count")
    ).where(
        func.date(db.ReviewLog.reviewed_at) >= start_date
    ).group_by(
        func.date(db.ReviewLog.reviewed_at)
    ).order_by(
        func.date(db.ReviewLog.reviewed_at)
    )
    
    results = session.exec(query).all()
    
    # Convertir a diccionario con formato de fecha string
    heatmap_data = {}
    for result in results:
        date_str = result.review_date.strftime("%Y-%m-%d")
        heatmap_data[date_str] = result.review_count
    
    return heatmap_data

@app.get("/api/v1/stats/streak-data", response_model=Dict[str, int])
def get_streak_data(session: Session = Depends(get_session)):
    """
    Calcula la racha actual de días consecutivos con repaso.
    """
    now = datetime.now(timezone.utc).date()
    
    # Obtener todas las fechas únicas de repaso en orden descendente
    query = select(
        func.date(db.ReviewLog.reviewed_at).label("review_date")
    ).distinct().order_by(
        func.date(db.ReviewLog.reviewed_at).desc()
    )
    
    review_dates = [result.review_date for result in session.exec(query).all()]
    
    if not review_dates:
        return {"current_streak": 0}

    current_streak = 0
    current_date = now
    
    # Si el día más reciente de repaso no es hoy ni ayer, la racha es 0
    most_recent = review_dates[0]
    if most_recent == now:
        # Repaso hecho hoy
        current_streak = 1
        current_date = now - timedelta(days=1)
    elif most_recent == now - timedelta(days=1):
        # Repaso hecho ayer
        current_streak = 1
        current_date = now - timedelta(days=2)
    else:
        # No hay repaso reciente, racha es 0
        return {"current_streak": 0}

    # Contar días consecutivos hacia atrás
    for review_date in review_dates[1:]:  # Saltar el primer elemento que ya contamos
        if review_date == current_date:
            current_streak += 1
            current_date -= timedelta(days=1)
        else:
            break  # La racha se rompió
    
    return {"current_streak": current_streak}

@app.post("/api/v1/import/markdown", response_model=m.ImportSummary)
async def import_deck_from_markdown(
    session: Session = Depends(get_session),
    file: UploadFile = File(...)
):
    """
    Importa un mazo desde un archivo Markdown.
    
    Formato esperado:
    # Nombre del Mazo
    
    **Descripción:** Descripción opcional del mazo
    
    ## Tarjetas
    
    ### Tarjeta 1
    **Anverso:**
    Contenido del anverso
    
    **Reverso:**
    Contenido del reverso
    
    **Etiquetas:** tag1, tag2, tag3
    
    ---
    
    ### Tarjeta 2
    ...
    """
    
    if not file.filename or not file.filename.endswith('.md'):
        raise HTTPException(status_code=400, detail="El archivo debe ser un archivo Markdown (.md)")
    
    try:
        # Leer contenido del archivo
        content = await file.read()
        markdown_text = content.decode('utf-8')
        
        # Parsear el contenido
        lines = markdown_text.split('\n')
        
        # Extraer nombre del mazo (primer h1)
        deck_name = None
        deck_description = None
        
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line.startswith('# '):
                deck_name = line[2:].strip()
                break
            i += 1
        
        if not deck_name:
            raise HTTPException(status_code=400, detail="No se encontró el nombre del mazo (debe comenzar con # )")
        
        # Buscar descripción opcional
        i += 1
        while i < len(lines):
            line = lines[i].strip()
            if line.startswith('**Descripción:**'):
                deck_description = line.replace('**Descripción:**', '').strip()
                break
            elif line.startswith('## Tarjetas'):
                break
            i += 1
        
        # Verificar si el mazo ya existe
        existing_deck = session.exec(select(db.Deck).where(db.Deck.name == deck_name)).first()
        if existing_deck:
            raise HTTPException(status_code=400, detail=f"Ya existe un mazo con el nombre '{deck_name}'")
        
        # Crear el mazo
        deck = db.Deck(name=deck_name, description=deck_description)
        session.add(deck)
        session.commit()
        session.refresh(deck)
        
        # Parsear tarjetas
        cards_created = 0
        warnings = []
        errors = []
        
        # Buscar inicio de las tarjetas
        cards_start = None
        for i, line in enumerate(lines):
            if line.strip() == '## Tarjetas':
                cards_start = i + 1
                break
        
        if cards_start is None:
            warnings.append("No se encontró la sección '## Tarjetas'")
            return m.ImportSummary(
                message=f"Mazo '{deck_name}' creado sin tarjetas",
                decks_created=1,
                cards_created=0,
                warnings=warnings,
                errors=errors
            )
        
        # Parsear cada tarjeta
        current_card = None
        current_section = None
        current_content = []
        
        for i in range(cards_start, len(lines)):
            line = lines[i]
            
            if line.startswith('### '):
                # Nueva tarjeta
                if current_card:
                    # Procesar tarjeta anterior
                    try:
                        card = process_markdown_card(current_card, deck.id)
                        session.add(card)
                        cards_created += 1
                    except Exception as e:
                        errors.append(f"Error procesando tarjeta: {str(e)}")
                
                # Iniciar nueva tarjeta
                current_card = {'front': '', 'back': '', 'tags': []}
                current_section = None
                current_content = []
                
            elif line.startswith('**Anverso:**'):
                if current_card:
                    current_section = 'front'
                    current_content = []
                    
            elif line.startswith('**Reverso:**'):
                if current_card and current_section == 'front':
                    current_card['front'] = '\n'.join(current_content).strip()
                current_section = 'back'
                current_content = []
                
            elif line.startswith('**Etiquetas:**'):
                if current_card and current_section == 'back':
                    current_card['back'] = '\n'.join(current_content).strip()
                # Parsear etiquetas
                tags_line = line.replace('**Etiquetas:**', '').strip()
                if tags_line:
                    tags = [tag.strip() for tag in tags_line.split(',') if tag.strip()]
                    current_card['tags'] = tags
                current_section = None
                current_content = []
                
            elif line.strip() == '---':
                # Fin de tarjeta
                if current_card and current_section == 'back':
                    current_card['back'] = '\n'.join(current_content).strip()
                current_section = None
                current_content = []
                
            elif current_section and not line.strip().startswith('**'):
                current_content.append(line)
        
        # Procesar última tarjeta
        if current_card:
            if current_section == 'back':
                current_card['back'] = '\n'.join(current_content).strip()
            try:
                card = process_markdown_card(current_card, deck.id)
                session.add(card)
                cards_created += 1
            except Exception as e:
                errors.append(f"Error procesando última tarjeta: {str(e)}")
        
        session.commit()
        
        return m.ImportSummary(
            message=f"Importación completada: mazo '{deck_name}' con {cards_created} tarjetas",
            decks_created=1,
            cards_created=cards_created,
            warnings=warnings,
            errors=errors
        )
        
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error importando archivo: {str(e)}")

def process_markdown_card(card_data: dict, deck_id: int) -> db.Card:
    """
    Procesa los datos de una tarjeta desde Markdown y crea un objeto Card.
    """
    
    def parse_md_content(md_str: Optional[str]) -> Any:
        """Convierte contenido Markdown a formato ContentBlock."""
        if not md_str:
            return [{"type": "text", "content": ""}]
        
        # Por simplicidad, convertir todo a texto plano por ahora
        # En el futuro se podría expandir para soportar imágenes, etc.
        return [{"type": "text", "content": md_str}]
    
    front_content = parse_md_content(card_data.get('front'))
    back_content = parse_md_content(card_data.get('back'))
    tags = card_data.get('tags', [])
    
    return db.Card(
        deck_id=deck_id,
        front_content=front_content,
        back_content=back_content,
        tags=tags if tags else None
    )

@app.get("/api/v1/sync/pull", response_model=m.PullResponse)
def sync_pull(
    *,
    session: Session = Depends(get_session),
    last_sync_timestamp_param: Optional[datetime] = Query(None, alias="lastSyncTimestamp")
):
    """
    Endpoint para pull de sincronización. 
    Devuelve todos los cambios desde el último timestamp proporcionado por el cliente.
    """
    server_timestamp = datetime.now(timezone.utc)
    
    if last_sync_timestamp_param:
        # Asegurar que el parámetro tenga timezone
        if last_sync_timestamp_param.tzinfo is None:
            last_sync_timestamp = last_sync_timestamp_param.replace(tzinfo=timezone.utc)
        else:
            last_sync_timestamp = last_sync_timestamp_param
        
        # Obtener mazos modificados desde el último sync
        decks_query = select(db.Deck).where(db.Deck.updated_at > last_sync_timestamp)
        cards_query = select(db.Card).where(db.Card.updated_at > last_sync_timestamp)
    else:
        # Primer sync, obtener todo
        decks_query = select(db.Deck)
        cards_query = select(db.Card)
    
    decks = session.exec(decks_query).all()
    cards = session.exec(cards_query).all()
    
    # Convertir a modelos de sincronización (que incluyen campos como is_deleted)
    deck_sync_reads = []
    for deck in decks:
        deck_sync_reads.append(m.DeckSyncRead(
            id=deck.id,
            name=deck.name,
            description=deck.description,
            created_at=deck.created_at,
            updated_at=deck.updated_at,
            is_deleted=False,  # Por ahora no manejamos soft delete
            deleted_at=None
        ))
    
    card_sync_reads = []
    for card in cards:
        card_sync_reads.append(m.CardSyncRead(
            id=card.id,
            deck_id=card.deck_id,
            front_content=card.front_content,
            back_content=card.back_content,
            raw_cloze_text=card.raw_cloze_text,
            cloze_data=card.cloze_data,
            tags=card.tags,
            next_review_at=card.next_review_at,
            fsrs_stability=card.fsrs_stability,
            fsrs_difficulty=card.fsrs_difficulty,
            fsrs_lapses=card.fsrs_lapses,
            fsrs_state=card.fsrs_state,
            created_at=card.created_at,
            updated_at=card.updated_at,
            is_deleted=False,  # Por ahora no manejamos soft delete
            deleted_at=None
        ))
    
    return m.PullResponse(
        server_timestamp=server_timestamp,
        decks=deck_sync_reads,
        cards=card_sync_reads
    )

@app.post("/api/v1/sync/push", response_model=m.PushResponse)
def sync_push(
    *,
    session: Session = Depends(get_session),
    payload: m.PushRequest
):
    """
    Endpoint para push de sincronización.
    Procesa cambios del cliente y retorna conflictos si los hay.
    """
    # Asegurar que client_timestamp tenga timezone
    if payload.client_timestamp.tzinfo is None:
        client_timestamp = payload.client_timestamp.replace(tzinfo=timezone.utc)
    else:
        client_timestamp = payload.client_timestamp
    
    conflicts = []
    created_decks = []
    created_cards = []
    
    # Procesar nuevos mazos del cliente
    if payload.new_decks:
        for new_deck_data in payload.new_decks:
            try:
                # Verificar si ya existe un mazo con ese nombre
                existing_deck = session.exec(
                    select(db.Deck).where(db.Deck.name == new_deck_data.name)
                ).first()
                
                if existing_deck:
                    # Conflicto: ya existe un mazo con ese nombre
                    conflicts.append(m.ConflictInfo(
                        type="new_deck_creation",
                        id=-1,  # No hay ID específico para un deck nuevo
                        identifier=new_deck_data.name,
                        message=f"Ya existe un mazo con el nombre '{new_deck_data.name}'"
                    ))
                    continue

                # Crear el nuevo mazo
                db_deck = db.Deck(
                    name=new_deck_data.name,
                    description=new_deck_data.description,
                    created_at=datetime.now(timezone.utc),
                    updated_at=datetime.now(timezone.utc)
                )
                session.add(db_deck)
                session.flush()  # Para obtener el ID
                
                # Convertir a DeckSyncRead para la respuesta
                created_deck = m.DeckSyncRead(
                    id=db_deck.id,
                    name=db_deck.name,
                    description=db_deck.description,
                    created_at=db_deck.created_at,
                    updated_at=db_deck.updated_at,
                    is_deleted=False,
                    deleted_at=None
                )
                created_decks.append(created_deck)
                
            except Exception as e:
                conflicts.append(m.ConflictInfo(
                    type="new_deck_creation",
                    id=-1,
                    identifier=new_deck_data.name,
                    message=f"Error creando mazo: {str(e)}"
                ))
    
    # Procesar nuevas tarjetas del cliente
    if payload.new_cards:
        for new_card_data in payload.new_cards:
            try:
                # Verificar que el deck existe
                deck = session.get(db.Deck, new_card_data.deck_id)
                if not deck:
                    conflicts.append(m.ConflictInfo(
                        type="new_card_creation",
                        id=-1,
                        identifier=f"deck_id:{new_card_data.deck_id}",
                        message=f"El mazo con ID {new_card_data.deck_id} no existe"
                    ))
                    continue
                
                # Procesar tarjeta cloze si tiene raw_cloze_text
                if new_card_data.raw_cloze_text:
                    try:
                        placeholder_pattern = r"\{\{c(\d+)::(.*?)::(.*?)\}\}"
                        cloze_matches = re.findall(placeholder_pattern, new_card_data.raw_cloze_text)
                        
                        if cloze_matches:
                            # Generar HTML para front y back
                            def replace_front_sync(match_obj, current_idx=i):
                                return f"<span class='cloze-blank'>[...]</span>"
                            
                            front_html = re.sub(placeholder_pattern, replace_front_sync, new_card_data.raw_cloze_text)
                            
                            def replace_back_sync(match_obj, current_idx=i):
                                answer = match_obj.group(2)
                                return f"<span class='cloze-answer'>{answer}</span>"
                            
                            back_html = re.sub(placeholder_pattern, replace_back_sync, new_card_data.raw_cloze_text)
                            
                            # Crear ContentBlocks
                            front_blocks = [{"type": "html", "content": front_html}]
                            back_blocks = [{"type": "html", "content": back_html}]
                            
                            cloze_data = {
                                "original_text": new_card_data.raw_cloze_text,
                                "matches": cloze_matches
                            }
                            
                            db_card = db.Card(
                                deck_id=new_card_data.deck_id,
                                front_content=front_blocks,
                                back_content=back_blocks,
                                raw_cloze_text=new_card_data.raw_cloze_text,
                                cloze_data=cloze_data,
                                tags=new_card_data.tags,
                                created_at=datetime.now(timezone.utc),
                                updated_at=datetime.now(timezone.utc)
                            )
                        else:
                            # Sin matches cloze válidos, crear como estándar
                            db_card = db.Card(
                                deck_id=new_card_data.deck_id,
                                front_content=new_card_data.front_content,
                                back_content=new_card_data.back_content,
                                raw_cloze_text=new_card_data.raw_cloze_text,
                                cloze_data=new_card_data.cloze_data,
                                tags=new_card_data.tags,
                                created_at=datetime.now(timezone.utc),
                                updated_at=datetime.now(timezone.utc)
                            )
                    except Exception as e:
                        print(f"Error procesando cloze en sync: {e}")
                        # Fallback: crear como tarjeta estándar
                        db_card = db.Card(
                            deck_id=new_card_data.deck_id,
                            front_content=new_card_data.front_content,
                            back_content=new_card_data.back_content,
                            raw_cloze_text=new_card_data.raw_cloze_text,
                            cloze_data=new_card_data.cloze_data,
                            tags=new_card_data.tags,
                            created_at=datetime.now(timezone.utc),
                            updated_at=datetime.now(timezone.utc)
                        )
                else:
                    # Tarjeta estándar
                    db_card = db.Card(
                        deck_id=new_card_data.deck_id,
                        front_content=new_card_data.front_content,
                        back_content=new_card_data.back_content,
                        tags=new_card_data.tags,
                        created_at=datetime.now(timezone.utc),
                        updated_at=datetime.now(timezone.utc)
                    )
                
                session.add(db_card)
                session.flush()  # Para obtener el ID
                
                # Convertir a CardSyncRead para la respuesta
                created_card = m.CardSyncRead(
                    id=db_card.id,
                    deck_id=db_card.deck_id,
                    front_content=db_card.front_content,
                    back_content=db_card.back_content,
                    raw_cloze_text=db_card.raw_cloze_text,
                    cloze_data=db_card.cloze_data,
                    tags=db_card.tags,
                    next_review_at=db_card.next_review_at,
                    fsrs_stability=db_card.fsrs_stability,
                    fsrs_difficulty=db_card.fsrs_difficulty,
                    fsrs_lapses=db_card.fsrs_lapses,
                    fsrs_state=db_card.fsrs_state,
                    created_at=db_card.created_at,
                    updated_at=db_card.updated_at,
                    is_deleted=False,
                    deleted_at=None
                )
                created_cards.append(created_card)
                
            except Exception as e:
                conflicts.append(m.ConflictInfo(
                    type="new_card_creation",
                    id=-1,
                    identifier=f"deck_id:{new_card_data.deck_id}",
                    message=f"Error creando tarjeta: {str(e)}"
                ))
    
    # Procesar mazos actualizados (updates y deletes)
    if payload.updated_decks:
        for updated_deck in payload.updated_decks:
            try:
                db_deck = session.get(db.Deck, updated_deck.id)
                if not db_deck:
                    conflicts.append(m.ConflictInfo(
                        type="deck",
                        id=updated_deck.id,
                        identifier=updated_deck.name,
                        message=f"Mazo con ID {updated_deck.id} no encontrado en el servidor"
                    ))
                    continue
                
                # Verificar conflictos de timestamp (si el servidor tiene una versión más nueva)
                if db_deck.updated_at.replace(tzinfo=timezone.utc) > client_timestamp:
                    conflicts.append(m.ConflictInfo(
                        type="deck",
                        id=updated_deck.id,
                        identifier=updated_deck.name,
                        message=f"El mazo ha sido modificado en el servidor después del último sync del cliente"
                    ))
                    continue
                
                # Aplicar cambios
                if updated_deck.is_deleted:
                    # Soft delete o hard delete según la implementación
                    session.delete(db_deck)
                else:
                    # Actualizar campos
                    if updated_deck.name is not None:
                        db_deck.name = updated_deck.name
                    if updated_deck.description is not None:
                        db_deck.description = updated_deck.description
                    db_deck.updated_at = datetime.now(timezone.utc)
                    session.add(db_deck)
                
            except Exception as e:
                conflicts.append(m.ConflictInfo(
                    type="deck",
                    id=updated_deck.id,
                    identifier=updated_deck.name,
                    message=f"Error actualizando mazo: {str(e)}"
                ))
    
    # Procesar tarjetas actualizadas (updates y deletes)
    if payload.updated_cards:
        for updated_card in payload.updated_cards:
            try:
                db_card = session.get(db.Card, updated_card.id)
                if not db_card:
                    conflicts.append(m.ConflictInfo(
                        type="card",
                        id=updated_card.id,
                        identifier=f"card_id:{updated_card.id}",
                        message=f"Tarjeta con ID {updated_card.id} no encontrada en el servidor"
                    ))
                    continue
                
                # Verificar conflictos de timestamp
                if db_card.updated_at.replace(tzinfo=timezone.utc) > client_timestamp:
                    conflicts.append(m.ConflictInfo(
                        type="card",
                        id=updated_card.id,
                        identifier=f"card_id:{updated_card.id}",
                        message=f"La tarjeta ha sido modificada en el servidor después del último sync del cliente"
                    ))
                    continue
                
                # Aplicar cambios
                if updated_card.is_deleted:
                    session.delete(db_card)
                else:
                    # Actualizar campos que no sean None
                    if updated_card.front_content is not None:
                        db_card.front_content = updated_card.front_content
                    if updated_card.back_content is not None:
                        db_card.back_content = updated_card.back_content
                    if updated_card.raw_cloze_text is not None:
                        db_card.raw_cloze_text = updated_card.raw_cloze_text
                    if updated_card.cloze_data is not None:
                        db_card.cloze_data = updated_card.cloze_data
                    if updated_card.tags is not None:
                        db_card.tags = updated_card.tags
                    
                    # Actualizar campos FSRS si están presentes
                    if updated_card.next_review_at is not None:
                        db_card.next_review_at = updated_card.next_review_at
                    if updated_card.fsrs_stability is not None:
                        db_card.fsrs_stability = updated_card.fsrs_stability
                    if updated_card.fsrs_difficulty is not None:
                        db_card.fsrs_difficulty = updated_card.fsrs_difficulty
                    if updated_card.fsrs_lapses is not None:
                        db_card.fsrs_lapses = updated_card.fsrs_lapses
                    if updated_card.fsrs_state is not None:
                        db_card.fsrs_state = updated_card.fsrs_state
                    
                    # Solo actualizar timestamp si realmente cambiaron datos
                    db_card.updated_at = datetime.now(timezone.utc)
                    session.add(db_card)
                
            except Exception as e:
                conflicts.append(m.ConflictInfo(
                    type="card",
                    id=updated_card.id,
                    identifier=f"card_id:{updated_card.id}",
                    message=f"Error actualizando tarjeta: {str(e)}"
                ))
    
    # Commit cambios
    try:
        session.commit()
        message = "Sincronización completada exitosamente"
        if conflicts:
            message += f" con {len(conflicts)} conflictos"
    except Exception as e:
        session.rollback()
        raise HTTPException(status_code=500, detail=f"Error guardando cambios: {str(e)}")
    
    return m.PushResponse(
        message=message,
        created_decks=created_decks if created_decks else None,
        created_cards=created_cards if created_cards else None,
        conflicts=conflicts if conflicts else None
    )

@app.get("/api/v1/settings", response_model=m.UserSettingsRead)
async def get_user_settings(
    *,
    session: Session = Depends(get_session),
    user_id: str = "default"
):
    """Obtiene la configuración del usuario."""
    settings = session.exec(
        select(db.UserSettings).where(db.UserSettings.user_id == user_id)
    ).first()
    
    if not settings:
        # Crear configuración por defecto si no existe
        default_settings = db.UserSettings(
            user_id=user_id,
            theme="light",
            language="es",
            cards_per_session=20,
            enable_sounds=True,
            enable_animations=True,
            auto_advance=False,
            show_progress=True,
            daily_goal=50,
            study_streak_notifications=True,
            review_reminder_time="09:00",
            weekend_reminders=True,
            card_font_size="medium",
            show_card_count=True,
            shuffle_new_cards=False,
            enable_keyboard_shortcuts=True,
            backup_frequency="weekly",
            data_retention_days=365,
            export_format="json",
            import_merge_strategy="skip_duplicates"
        )
        session.add(default_settings)
        session.commit()
        session.refresh(default_settings)
        settings = default_settings
    
    return settings

@app.put("/api/v1/settings", response_model=m.UserSettingsRead)
async def update_user_settings(
    *,
    session: Session = Depends(get_session),
    settings_update: m.UserSettingsUpdate,
    user_id: str = "default"
):
    """Actualiza la configuración del usuario."""
    settings = session.exec(
        select(db.UserSettings).where(db.UserSettings.user_id == user_id)
    ).first()
    
    if not settings:
        # Crear nueva configuración si no existe
        settings = db.UserSettings(user_id=user_id)
        session.add(settings)
    
    # Actualizar solo los campos proporcionados
    update_data = settings_update.model_dump(exclude_unset=True)
    for field, value in update_data.items():
        setattr(settings, field, value)
    
    # Actualizar timestamp
    settings.updated_at = datetime.now(timezone.utc)
    
    session.commit()
    session.refresh(settings)
    
    return settings

@app.post("/api/v1/settings/reset", response_model=m.UserSettingsResetResponse)
async def reset_user_settings(
    *,
    session: Session = Depends(get_session),
    user_id: str = "default"
):
    """Restablece la configuración del usuario a los valores por defecto."""
    settings = session.exec(
        select(db.UserSettings).where(db.UserSettings.user_id == user_id)
    ).first()
    
    if settings:
        # Guardar configuración anterior para el log
        previous_config = {
            "theme": settings.theme,
            "language": settings.language,
            "cards_per_session": settings.cards_per_session,
            "daily_goal": settings.daily_goal
        }
        
        # Restablecer a valores por defecto
        settings.theme = "light"
        settings.language = "es"
        settings.cards_per_session = 20
        settings.enable_sounds = True
        settings.enable_animations = True
        settings.auto_advance = False
        settings.show_progress = True
        settings.daily_goal = 50
        settings.study_streak_notifications = True
        settings.review_reminder_time = "09:00"
        settings.weekend_reminders = True
        settings.card_font_size = "medium"
        settings.show_card_count = True
        settings.shuffle_new_cards = False
        settings.enable_keyboard_shortcuts = True
        settings.backup_frequency = "weekly"
        settings.data_retention_days = 365
        settings.export_format = "json"
        settings.import_merge_strategy = "skip_duplicates"
        settings.updated_at = datetime.now(timezone.utc)
        
        session.commit()
        session.refresh(settings)
        
        return m.UserSettingsResetResponse(
            message="Configuración restablecida a valores por defecto",
            reset_at=settings.updated_at,
            previous_config=previous_config,
            current_config=settings
        )
    else:
        # Crear configuración por defecto
        default_settings = db.UserSettings(user_id=user_id)
        session.add(default_settings)
        session.commit()
        session.refresh(default_settings)
        
        return m.UserSettingsResetResponse(
            message="Configuración creada con valores por defecto",
            reset_at=default_settings.updated_at,
            previous_config={},
            current_config=default_settings
        )

@app.get("/api/v1/settings/export")
async def export_user_settings(
    *,
    session: Session = Depends(get_session),
    user_id: str = "default"
):
    """Exporta la configuración del usuario como archivo JSON."""
    settings = session.exec(
        select(db.UserSettings).where(db.UserSettings.user_id == user_id)
    ).first()
    
    if not settings:
        raise HTTPException(status_code=404, detail="Configuración no encontrada")
    
    # Preparar datos para exportación
    export_data = {
        "export_info": {
            "version": "1.0",
            "exported_at": datetime.now(timezone.utc).isoformat(),
            "user_id": user_id,
            "app_name": "Juanpa Spaced Repetition"
        },
        "settings": {
            "theme": settings.theme,
            "language": settings.language,
            "cards_per_session": settings.cards_per_session,
            "enable_sounds": settings.enable_sounds,
            "enable_animations": settings.enable_animations,
            "auto_advance": settings.auto_advance,
            "show_progress": settings.show_progress,
            "daily_goal": settings.daily_goal,
            "study_streak_notifications": settings.study_streak_notifications,
            "review_reminder_time": settings.review_reminder_time,
            "weekend_reminders": settings.weekend_reminders,
            "card_font_size": settings.card_font_size,
            "show_card_count": settings.show_card_count,
            "shuffle_new_cards": settings.shuffle_new_cards,
            "enable_keyboard_shortcuts": settings.enable_keyboard_shortcuts,
            "backup_frequency": settings.backup_frequency,
            "data_retention_days": settings.data_retention_days,
            "export_format": settings.export_format,
            "import_merge_strategy": settings.import_merge_strategy
        }
    }
    
    # Convertir a JSON
    json_content = json.dumps(export_data, indent=2, ensure_ascii=False)
    
    # Generar nombre de archivo
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"juanpa_settings_{user_id}_{timestamp}.json"
    
    return Response(
        content=json_content,
        media_type="application/json",
        headers={
            "Content-Disposition": f"attachment; filename=\"{filename}\""
        }
    )

@app.post("/api/v1/settings/import", response_model=m.UserSettingsRead)
async def import_user_settings(
    *,
    session: Session = Depends(get_session),
    file: UploadFile = File(...),
    user_id: str = "default"
):
    """Importa configuración del usuario desde un archivo JSON."""
    
    if not file.filename or not file.filename.endswith('.json'):
        raise HTTPException(
            status_code=400, 
            detail="El archivo debe ser un archivo JSON (.json)"
        )
    
    try:
        # Leer contenido del archivo
        content = await file.read()
        import_data = json.loads(content.decode('utf-8'))
        
        # Validar estructura básica
        if "settings" not in import_data:
            raise HTTPException(
                status_code=400,
                detail="Archivo JSON inválido: falta la sección 'settings'"
            )
        
        settings_data = import_data["settings"]
        
        # Obtener configuración actual
        current_settings = session.exec(
            select(db.UserSettings).where(db.UserSettings.user_id == user_id)
        ).first()
        
        if not current_settings:
            # Crear nueva configuración
            current_settings = db.UserSettings(user_id=user_id)
            session.add(current_settings)
        
        # Mapear y validar campos
        valid_fields = {
            "theme": str,
            "language": str,
            "cards_per_session": int,
            "enable_sounds": bool,
            "enable_animations": bool,
            "auto_advance": bool,
            "show_progress": bool,
            "daily_goal": int,
            "study_streak_notifications": bool,
            "review_reminder_time": str,
            "weekend_reminders": bool,
            "card_font_size": str,
            "show_card_count": bool,
            "shuffle_new_cards": bool,
            "enable_keyboard_shortcuts": bool,
            "backup_frequency": str,
            "data_retention_days": int,
            "export_format": str,
            "import_merge_strategy": str
        }
        
        # Aplicar configuraciones válidas
        updated_fields = []
        for field, expected_type in valid_fields.items():
            if field in settings_data:
                try:
                    value = settings_data[field]
                    
                    # Validación básica de tipo
                    if not isinstance(value, expected_type):
                        continue  # Saltar campos con tipo incorrecto
                    
                    # Validaciones específicas
                    if field == "theme" and value not in ["light", "dark", "auto"]:
                        continue
                    if field == "language" and value not in ["es", "en"]:
                        continue
                    if field == "cards_per_session" and not (1 <= value <= 100):
                        continue
                    if field == "daily_goal" and not (1 <= value <= 1000):
                        continue
                    if field == "card_font_size" and value not in ["small", "medium", "large"]:
                        continue
                    if field == "backup_frequency" and value not in ["daily", "weekly", "monthly"]:
                        continue
                    if field == "data_retention_days" and not (30 <= value <= 3650):
                        continue
                    if field == "export_format" and value not in ["json", "csv", "xml"]:
                        continue
                    if field == "import_merge_strategy" and value not in ["overwrite", "skip_duplicates", "merge"]:
                        continue
                    
                    # Aplicar valor válido
                    setattr(current_settings, field, value)
                    updated_fields.append(field)
                    
                except (ValueError, TypeError):
                    continue  # Saltar campos con errores de conversión
        
        # Actualizar timestamp
        current_settings.updated_at = datetime.now(timezone.utc)
        
        session.commit()
        session.refresh(current_settings)
        
        logger.info(f"Configuración importada para usuario {user_id}. Campos actualizados: {updated_fields}")
        
        return current_settings
        
    except json.JSONDecodeError:
        raise HTTPException(
            status_code=400,
            detail="Archivo JSON inválido: no se pudo parsear el contenido"
        )
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail=f"Error importando configuración: {str(e)}"
        )

@app.get("/api/v1/gemini/status", response_model=m.GeminiStatusResponse)
async def get_gemini_status():
    """Verifica el estado y disponibilidad del servicio Gemini."""
    
    if not GEMINI_AVAILABLE:
        return m.GeminiStatusResponse(
            available=False,
            model=None,
            api_key_configured=False,
            last_error="Gemini service module not available"
        )
    
    try:
        # Verificar si Gemini está disponible y configurado
        is_available = is_gemini_available()
        
        if is_available:
            # Obtener información del generador
            generator = get_gemini_generator()
            model_name = getattr(generator, 'model_name', 'gemini-2.0-flash-exp') if generator else None
            
            return m.GeminiStatusResponse(
                available=True,
                model=model_name,
                api_key_configured=True,
                last_error=None
            )
        else:
            return m.GeminiStatusResponse(
                available=False,
                model=None,
                api_key_configured=False,
                last_error="API key not configured or invalid"
            )
            
    except Exception as e:
        return m.GeminiStatusResponse(
            available=False,
            model=None,
            api_key_configured=False,
            last_error=str(e)
        )

@app.post("/api/v1/gemini/generate-cards", response_model=m.CardGenerationResult)
async def generate_cards_with_gemini(
    *,
    session: Session = Depends(get_session),
    request: m.CardGenerationRequest
):
    """Genera tarjetas usando Gemini AI."""
    
    if not GEMINI_AVAILABLE:
        raise HTTPException(
            status_code=503,
            detail="Servicio Gemini no disponible. Verifica la configuración."
        )
    
    if not is_gemini_available():
        raise HTTPException(
            status_code=503,
            detail="Gemini no está configurado correctamente. Verifica la API key."
        )
    
    # Verificar que el deck existe
    deck = session.get(db.Deck, request.deck_id)
    if not deck:
        raise HTTPException(
            status_code=404,
            detail=f"Deck con ID {request.deck_id} no encontrado"
        )
    
    try:
        start_time = time.time()
        
        # Obtener el generador de Gemini
        generator = get_gemini_generator()
        
        # Crear la solicitud para Gemini
        gemini_request = GeminiCardRequest(
            topic=request.topic,
            num_cards=request.num_cards or 10,
            difficulty=request.difficulty or 'medium',
            card_type=request.card_type or 'standard',
            language=request.language or 'es',
            context=request.context
        )
        
        # Generar tarjetas con Gemini
        gemini_response = await generator.generate_cards(gemini_request)
        
        if not gemini_response.success:
            return m.CardGenerationResult(
                success=False,
                cards_created=[],
                metadata={
                    "topic": request.topic,
                    "requested_count": request.num_cards,
                    "generated_count": 0,
                    "deck_id": request.deck_id,
                    "deck_name": deck.name,
                    "generation_time_seconds": time.time() - start_time
                },
                errors=gemini_response.errors or ["Error desconocido en la generación"],
                warnings=gemini_response.warnings
            )
        
        # Procesar y guardar las tarjetas generadas
        created_cards = []
        for card_data in gemini_response.cards_data:
            try:
                # Determinar si es tarjeta cloze
                is_cloze = card_data.get('type') == 'cloze' or card_data.get('raw_cloze_text')
                
                if is_cloze and card_data.get('raw_cloze_text'):
                    # Procesar tarjeta cloze
                    placeholder_pattern = r"\{\{c(\d+)::(.*?)::(.*?)\}\}"
                    cloze_matches = re.findall(placeholder_pattern, card_data['raw_cloze_text'])
                    
                    if cloze_matches:
                        # Generar HTML para front y back
                        def replace_front(match_obj):
                            return f"<span class='cloze-blank'>[...]</span>"
                        
                        front_html = re.sub(placeholder_pattern, replace_front, card_data['raw_cloze_text'])
                        
                        def replace_back(match_obj):
                            answer = match_obj.group(2)
                            return f"<span class='cloze-answer'>{answer}</span>"
                        
                        back_html = re.sub(placeholder_pattern, replace_back, card_data['raw_cloze_text'])
                        
                        # Crear ContentBlocks
                        front_blocks = [{"type": "html", "content": front_html}]
                        back_blocks = [{"type": "html", "content": back_html}]
                        
                        cloze_data = {
                            "original_text": card_data['raw_cloze_text'],
                            "matches": cloze_matches
                        }
                        
                        db_card = db.Card(
                            deck_id=request.deck_id,
                            front_content=front_blocks,
                            back_content=back_blocks,
                            raw_cloze_text=card_data['raw_cloze_text'],
                            cloze_data=cloze_data,
                            tags=card_data.get('tags', []),
                            created_at=datetime.now(timezone.utc),
                            updated_at=datetime.now(timezone.utc)
                        )
                    else:
                        # Sin matches cloze válidos, crear como estándar
                        front_content = [{"type": "text", "content": card_data.get('front', '')}]
                        back_content = [{"type": "text", "content": card_data.get('back', '')}]
                        
                        db_card = db.Card(
                            deck_id=request.deck_id,
                            front_content=front_content,
                            back_content=back_content,
                            tags=card_data.get('tags', []),
                            created_at=datetime.now(timezone.utc),
                            updated_at=datetime.now(timezone.utc)
                        )
                else:
                    # Tarjeta estándar
                    front_content = [{"type": "text", "content": card_data.get('front', '')}]
                    back_content = [{"type": "text", "content": card_data.get('back', '')}]
                    
                    db_card = db.Card(
                        deck_id=request.deck_id,
                        front_content=front_content,
                        back_content=back_content,
                        tags=card_data.get('tags', []),
                        created_at=datetime.now(timezone.utc),
                        updated_at=datetime.now(timezone.utc)
                    )
                
                session.add(db_card)
                session.flush()  # Para obtener el ID
                created_cards.append(db_card)
                
            except Exception as e:
                print(f"Error procesando tarjeta: {e}")
                continue
        
        # Confirmar cambios
        session.commit()
        
        # Convertir a response models
        card_responses = []
        for card in created_cards:
            session.refresh(card)  # Asegurar que tenemos todos los datos
            card_responses.append(m.CardRead.model_validate(card))
        
        generation_time = time.time() - start_time
        
        return m.CardGenerationResult(
            success=True,
            cards_created=card_responses,
            metadata={
                "topic": request.topic,
                "requested_count": request.num_cards,
                "generated_count": len(created_cards),
                "difficulty": request.difficulty,
                "card_type": request.card_type,
                "language": request.language,
                "model_used": gemini_response.model_used,
                "generation_time_seconds": generation_time,
                "deck_id": request.deck_id,
                "deck_name": deck.name
            },
            errors=None,
            warnings=gemini_response.warnings
        )
        
    except HTTPException:
        raise
    except Exception as e:
        print(f"Error en generación con Gemini: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Error generando tarjetas: {str(e)}"
        ) 