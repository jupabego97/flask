@app.post("/api/v1/upload/image/")
async def upload_image(file: UploadFile = File(...)):
    """Sube una imagen y la valida usando el sistema de validación robusto."""
    start_time = time.time()
    logger.operation_start("upload_image", filename=file.filename)
    
    try:
        # Validar archivo usando el nuevo validador
        if not file.filename:
            raise FileProcessingError("Nombre de archivo requerido")
        
        # Obtener tamaño del archivo
        file_content = await file.read()
        file_size = len(file_content)
        
        # Validar usando FileValidator
        FileValidator.validate_uploaded_file(
            filename=file.filename,
            content_type=file.content_type,
            file_size=file_size,
            file_category="image"
        )
        
        # Generar nombre único
        file_extension = os.path.splitext(file.filename)[1] if file.filename else ".png"
        unique_filename = f"{uuid.uuid4()}{file_extension}"
        file_path = os.path.join(UPLOADS_DIR, unique_filename)
        
        # Guardar archivo
        with open(file_path, "wb") as buffer:
            buffer.write(file_content)
        
        image_url = f"/static/uploads/images/{unique_filename}"
        
        execution_time = time.time() - start_time
        logger.operation_success(
            "upload_image",
            execution_time=execution_time,
            filename=file.filename,
            file_size=file_size,
            saved_path=image_url
        )
        
        return {"imageUrl": image_url}
        
    except JuanPAException as exc:
        execution_time = time.time() - start_time
        logger.operation_error("upload_image", exc, execution_time)
        raise to_http_exception(exc)
        
    except Exception as exc:
        execution_time = time.time() - start_time
        logger.operation_error("upload_image", exc, execution_time)
        raise HTTPException(status_code=500, detail=f"Error al guardar el archivo: {exc}")
    
    finally:
        # Asegurar que el archivo se cierre
        if hasattr(file, 'file') and file.file:
            file.file.close()

@app.post("/api/v1/decks/", response_model=m.DeckRead)
def create_deck(*, session: Session = Depends(get_session), deck_in: m.DeckCreate):
    existing_deck = session.exec(select(db.Deck).where(db.Deck.name == deck_in.name)).first()
    if existing_deck:
        raise HTTPException(status_code=400, detail=f"Deck with name '{deck_in.name}' already exists.")
    db_deck = db.Deck.model_validate(deck_in)
    session.add(db_deck)
    session.commit()
    session.refresh(db_deck)
    return db_deck

@app.get("/api/v1/decks/", response_model=List[m.DeckRead])
def read_decks(*, session: Session = Depends(get_session), skip: int = 0, limit: int = 100):
    decks = session.exec(select(db.Deck).offset(skip).limit(limit)).all()
    return decks

@app.get("/api/v1/decks/{deck_id}", response_model=m.DeckReadWithCards)
def read_deck(*, session: Session = Depends(get_session), deck_id: int):
    deck = session.get(db.Deck, deck_id)
    if not deck:
        raise HTTPException(status_code=404, detail="Deck not found")
    return deck

@app.put("/api/v1/decks/{deck_id}", response_model=m.DeckRead)
def update_deck(*, session: Session = Depends(get_session), deck_id: int, deck_in: m.DeckUpdate ):
    db_deck = session.get(db.Deck, deck_id)
    if not db_deck:
        raise HTTPException(status_code=404, detail="Deck not found")
    if deck_in.name and deck_in.name != db_deck.name:
        existing_deck_with_new_name = session.exec(select(db.Deck).where(db.Deck.name == deck_in.name)).first()
        if existing_deck_with_new_name:
            raise HTTPException(status_code=400, detail=f"Another deck with name '{deck_in.name}' already exists.")
    deck_data = deck_in.model_dump(exclude_unset=True)
    for key, value in deck_data.items():
        setattr(db_deck, key, value)
    session.add(db_deck)
    session.commit()
    session.refresh(db_deck)
    return db_deck

@app.delete("/api/v1/decks/{deck_id}", response_model=m.DeckRead)
def delete_deck(*, session: Session = Depends(get_session), deck_id: int):
    deck = session.get(db.Deck, deck_id)
    if not deck:
        raise HTTPException(status_code=404, detail="Deck not found")
    session.delete(deck)
    session.commit()
    return deck

# --- Endpoint para Exportar Mazo a Markdown ---

def format_card_content_to_markdown(content: Any) -> str:
    """
    Formatea el contenido de una cara de la tarjeta (que puede ser JSON) a Markdown.
    """
    if content is None:
        return ""
    if isinstance(content, list): # Probablemente una lista de ContentBlock
        md_parts = []
        for block in content:
            if isinstance(block, dict):
                block_type = block.get("type")
                block_content = block.get("content")
                block_src = block.get("src")
                block_alt = block.get("alt")
                block_placeholders = block.get("textWithPlaceholders")

                if block_type == "text" and block_content:
                    md_parts.append(str(block_content))
                elif block_type == "html" and block_content: # Para Cloze
                    md_parts.append(str(block_content)) # Asumimos que el HTML es seguro o se sanitizará en otro lado
                elif block_type == "image" and block_src:
                    md_parts.append(f"![{block_alt or 'imagen'}]({block_src})")
                elif block_type == "audio" and block_src:
                    md_parts.append(f"[Audio]({block_src})")
                elif block_type == "cloze_text" and block_placeholders:
                     md_parts.append(str(block_placeholders)) # Representación simple para Markdown
                elif block_content: # Fallback para otros tipos con 'content'
                    md_parts.append(str(block_content))
            else: # Si un elemento de la lista no es un dict, stringify
                md_parts.append(str(block))
        return "\n\n".join(md_parts)
    elif isinstance(content, dict): # Si es un solo objeto ContentBlock o similar
        if 'text' in content: # Caso simple de {"text": "..."}
             return str(content['text'])
        # Para otros dicts, un pretty print JSON
        return f"```json\n{json.dumps(content, indent=2, ensure_ascii=False)}\n```"
    # Si es un string simple u otro tipo
    return str(content)

@app.get("/api/v1/decks/{deck_id}/export/markdown", response_class=Response)
def export_deck_to_markdown(deck_id: int, session: Session = Depends(get_session)):
    deck = session.get(db.Deck, deck_id)
    if not deck:
        raise HTTPException(status_code=404, detail="Deck not found")

    markdown_content = f"# Mazo: {deck.name}\n\n"
    if deck.description:
        markdown_content += f"**Descripción:** {deck.description}\n\n"
    
    markdown_content += "## Tarjetas\n\n"

    # Usar la relación para obtener las tarjetas, ya que DeckReadWithCards las carga
    # O hacer una consulta separada si es más eficiente o si la relación no está cargada
    # Para la exportación, una consulta separada es clara:
    cards = session.exec(select(db.Card).where(db.Card.deck_id == deck_id).order_by(asc(db.Card.id))).all()

    if not cards:
        markdown_content += "Este mazo no tiene tarjetas.\n"
    else:
        for i, card in enumerate(cards):
            markdown_content += f"### Tarjeta {i + 1} (ID: {card.id})\n\n" # Añadir ID para referencia
            markdown_content += "**Anverso:**\n"
            markdown_content += format_card_content_to_markdown(card.front_content) + "\n\n"
            
            markdown_content += "**Reverso:**\n"
            markdown_content += format_card_content_to_markdown(card.back_content) + "\n\n"
            
            if card.tags:
                markdown_content += f"**Etiquetas:** {', '.join(card.tags)}\n\n"
            
            if card.cloze_data and isinstance(card.cloze_data, dict) and card.cloze_data.get('original_text'):
                 markdown_content += f"**Texto Cloze Original:**\n```\n{card.cloze_data['original_text']}\n```\n\n"

            markdown_content += "---\n\n"
            
    safe_deck_name = "".join(c if c.isalnum() else "_" for c in deck.name)
    filename = f"deck_{safe_deck_name}_export.md"
    
    return Response(
        content=markdown_content,
        media_type="text/markdown; charset=utf-8",
        headers={"Content-Disposition": f"attachment; filename=\"{filename}\""} # Comillas en filename
    )

@app.post("/api/v1/cards/", response_model=List[m.CardRead])
def create_card(*, session: Session = Depends(get_session), card_in: m.CardCreate):
    deck = session.get(db.Deck, card_in.deck_id)
    if not deck:
        raise HTTPException(status_code=404, detail="Deck not found")
    
    # Procesar imágenes en contenido
    if card_in.raw_cloze_text:
        # Procesar Cloze text directamente
        try:
            placeholder_pattern = r"\{\{c(\d+)::(.*?)::(.*?)\}\}"
            cloze_matches = re.findall(placeholder_pattern, card_in.raw_cloze_text)
            
            # Generar HTML para front y back
            if cloze_matches:
                # Para el front, reemplazar con [...] y mostrar full text con huecos
                def replace_front(match_obj):
                    return f"<span class='cloze-blank'>[...]</span>"
                
                front_html = re.sub(placeholder_pattern, replace_front, card_in.raw_cloze_text)
                
                # Para el back, reemplazar con las respuestas resaltadas
                def replace_back(match_obj):
                    answer = match_obj.group(2)
                    return f"<span class='cloze-answer'>{answer}</span>"
                
                back_html = re.sub(placeholder_pattern, replace_back, card_in.raw_cloze_text)
                
                # Crear ContentBlocks para front y back
                front_blocks = [{"type": "html", "content": front_html}]
                back_blocks = [{"type": "html", "content": back_html}]
                
                # Datos de procesamiento para cloze
                cloze_data = {
                    "original_text": card_in.raw_cloze_text,
                    "matches": cloze_matches
                }
                
                # Crear la tarjeta con los datos procesados
                db_card = db.Card(
                    deck_id=card_in.deck_id,
                    front_content=front_blocks,
                    back_content=back_blocks,
                    raw_cloze_text=card_in.raw_cloze_text,
                    cloze_data=cloze_data,
                    tags=card_in.tags
                )
            else:
                # Si no hay matches válidos, crear tarjeta estándar
                db_card = db.Card.model_validate(card_in)
        except Exception as e:
            print(f"Error procesando cloze: {e}")
            # Fallback: crear como tarjeta estándar
            db_card = db.Card.model_validate(card_in)
    else:
        # Tarjeta estándar
        db_card = db.Card.model_validate(card_in)
    
    session.add(db_card)
    session.commit()
    session.refresh(db_card)
    return [db_card]

